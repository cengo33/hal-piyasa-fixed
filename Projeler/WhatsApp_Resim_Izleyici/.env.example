# ═══════════════════════════════════════════════════════
# WhatsApp Resim İzleyici — Yapılandırma
# ═══════════════════════════════════════════════════════

# ── E-posta Ayarları (Gmail SMTP) ──
# Gmail'de "App Password" oluşturmanız gerekir:
# Google Hesabı → Güvenlik → 2 Adımlı Doğrulama → Uygulama Şifreleri
SMTP_EMAIL=sizin@gmail.com
SMTP_PASSWORD=abcd efgh ijkl mnop
NOTIFY_EMAIL=bildirim-gonderilecek@email.com

# ── İzlenecek Hedef ──
# Telefon numarası VEYA grup adı yazın (ikisi birden de olabilir)
WHATSAPP_PHONE=+90 507 623 15 10
WHATSAPP_GROUP_NAME=

# ── İzleme Aralığı (saniye) ──
CHECK_INTERVAL=10

# ── İndirilen resimlerin saklanacağı klasör ──
DOWNLOAD_DIR=./downloads
